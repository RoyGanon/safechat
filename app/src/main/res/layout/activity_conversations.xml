<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="40dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal"
        android:background="@color/sc_card"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/conversations_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/sc_text"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/logout"
            android:background="@drawable/bg_btn_outline"
            android:textColor="@color/sc_primary"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"/>
    </LinearLayout>

    <!-- TEACHER EXTRA ACTION -->
    <Button
        android:id="@+id/btnManageReports"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="12dp"
        android:text="Manage Exceptional Events"
        android:background="@drawable/bg_btn_outline"
        android:textColor="@color/sc_primary"
        android:visibility="gone" />

    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- PRIMARY ACTION -->
    <Button
        android:id="@+id/btnNewChat"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/new_chat"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_primary_btn"
        android:textColor="@color/white"/>
</LinearLayout>